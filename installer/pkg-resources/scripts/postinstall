#!/bin/bash
# Runs as root after .pkg payload is in place.
# Opens Terminal as the actual user and runs install.sh from the payload.

USER_NAME=$(stat -f %Su /dev/console)
SETUP_SCRIPT="/private/var/tmp/lp-generator-installer/install.sh"

if [ ! -f "$SETUP_SCRIPT" ]; then
  echo "ERROR: $SETUP_SCRIPT not found" >&2
  exit 1
fi

chmod +x "$SETUP_SCRIPT"
chown "$USER_NAME":staff "$SETUP_SCRIPT" 2>/dev/null || true

# Open Terminal as the user with our setup script.
# Drop privileges via sudo -u so Terminal launches in the user's session.
sudo -u "$USER_NAME" osascript <<APPLESCRIPT
tell application "Terminal"
    activate
    do script "bash '$SETUP_SCRIPT'"
end tell
APPLESCRIPT

exit 0
